{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "format.schema.json",
    "title": "GicaTesis Format Schema — Canonical v2",
    "description": "Schema canónico para formatos de tesis. Toda universidad sigue esta misma estructura.",
    "type": "object",
    "required": [
        "_meta",
        "configuracion",
        "caratula",
        "cuerpo"
    ],
    "properties": {
        "_meta": {
            "type": "object",
            "required": ["id", "university"],
            "properties": {
                "entity": { "const": "format" },
                "publish": { "type": "boolean" },
                "id": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Identificador único del formato (ej. unac-informe-cuant)"
                },
                "university": {
                    "type": "string",
                    "minLength": 1,
                    "pattern": "^[a-z0-9_-]+$",
                    "description": "Código de universidad en minúsculas (ej. unac, uni)"
                },
                "category": { "type": "string" },
                "documentType": { "type": "string" },
                "title": { "type": "string" },
                "version": { "type": "string" },
                "descripcion": { "type": "string" },
                "fecha": { "type": "string" }
            },
            "additionalProperties": true
        },
        "configuracion": {
            "type": "object",
            "required": ["ruta_logo"],
            "properties": {
                "ruta_logo": {
                    "type": "string",
                    "description": "Ruta al logo relativa a la raíz del proyecto (ej. app/static/assets/LogoUNAC.png)"
                }
            },
            "additionalProperties": true
        },
        "caratula": {
            "type": "object",
            "required": ["universidad", "facultad", "titulo_placeholder"],
            "properties": {
                "universidad": { "type": "string", "description": "Nombre completo de la universidad" },
                "facultad": { "type": "string" },
                "escuela": { "type": "string" },
                "tipo_documento": { "type": "string" },
                "titulo_placeholder": { "type": "string", "description": "Placeholder del título de tesis" },
                "frase_grado": { "type": "string" },
                "grado_objetivo": { "type": "string", "description": "Grado o carrera del autor" },
                "label_autor": { "type": "string" },
                "autor_valor": { "type": "string" },
                "label_asesor": { "type": "string" },
                "asesor_valor": { "type": "string" },
                "label_linea": { "type": "string" },
                "lugar": { "type": "string", "description": "Ciudad / País" },
                "anio": { "type": "string", "description": "Año de presentación" }
            },
            "additionalProperties": false
        },
        "preliminares": {
            "type": "object",
            "properties": {
                "dedicatoria": { "$ref": "#/definitions/seccion_texto" },
                "agradecimiento": { "$ref": "#/definitions/seccion_texto" },
                "agradecimientos": { "$ref": "#/definitions/seccion_texto" },
                "resumen": { "$ref": "#/definitions/seccion_texto" },
                "introduccion": { "$ref": "#/definitions/seccion_texto" },
                "indices": {
                    "type": "object",
                    "properties": {
                        "contenido": { "type": "string" },
                        "tablas": { "type": "string" },
                        "figuras": { "type": "string" }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": true
        },
        "cuerpo": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/definitions/capitulo" },
            "description": "Capítulos del documento"
        },
        "finales": {
            "type": "object",
            "properties": {
                "referencias": {
                    "oneOf": [
                        { "type": "string" },
                        {
                            "type": "object",
                            "properties": {
                                "titulo": { "type": "string" },
                                "nota": { "type": "string" },
                                "ejemplos": { "type": "array", "items": { "type": "string" } },
                                "ejemplos_apa": { "type": "array", "items": { "type": "string" } }
                            }
                        }
                    ]
                },
                "anexos": {
                    "type": "object",
                    "properties": {
                        "titulo_seccion": { "type": "string" },
                        "nota": { "type": "string" },
                        "lista": { "type": "array" }
                    }
                },
                "contenido": { "type": "array" }
            },
            "additionalProperties": true
        },
        "matriz_consistencia": {
            "type": "object",
            "properties": {
                "problemas": { "$ref": "#/definitions/objetivo_grupo" },
                "objetivos": { "$ref": "#/definitions/objetivo_grupo" },
                "hipotesis": { "$ref": "#/definitions/objetivo_grupo" },
                "variables": { "type": "object" },
                "metodologia": { "type": "object" }
            }
        }
    },
    "additionalProperties": false,
    "definitions": {
        "seccion_texto": {
            "type": "object",
            "properties": {
                "titulo": { "type": "string" },
                "texto": { "type": "string" }
            },
            "additionalProperties": true
        },
        "capitulo": {
            "type": "object",
            "required": ["titulo"],
            "properties": {
                "titulo": { "type": "string", "description": "Título del capítulo" },
                "nota_capitulo": { "type": "string", "description": "Instrucción o nota para el capítulo" },
                "vista_previa": { "type": "string" },
                "tipo_vista": { "type": "string" },
                "contenido": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/contenido_item" },
                    "description": "Contenido del capítulo (secciones, tablas, figuras)"
                },
                "ejemplos_apa": {
                    "type": "array",
                    "items": { "type": "string" }
                }
            },
            "additionalProperties": false
        },
        "contenido_item": {
            "oneOf": [
                { "type": "string" },
                { "$ref": "#/definitions/tabla" },
                { "$ref": "#/definitions/seccion_contenido" }
            ]
        },
        "seccion_contenido": {
            "type": "object",
            "properties": {
                "texto": { "type": "string", "description": "Subtítulo o texto de la sección" },
                "instruccion_detallada": { "type": "string" },
                "nota": { "type": "string" },
                "parrafos": {
                    "type": "array",
                    "items": { "type": "string" },
                    "description": "Párrafos o sub-items del contenido"
                },
                "imagenes": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/imagen" }
                },
                "tabla": { "type": "object" },
                "tabla_titulo": { "type": "string" },
                "tabla_nota": { "type": "string" },
                "tablas_especiales": { "type": "array" },
                "mostrar_matriz": { "type": "boolean" }
            },
            "additionalProperties": true
        },
        "imagen": {
            "type": "object",
            "properties": {
                "titulo": { "type": "string" },
                "ruta": { "type": "string" },
                "fuente": { "type": "string" }
            },
            "additionalProperties": false
        },
        "tabla": {
            "type": "object",
            "description": "Tabla renderizable en DOCX con soporte portrait/landscape, fusión de celdas y estilos.",
            "required": ["tipo", "titulo", "encabezados", "filas"],
            "properties": {
                "tipo": { "const": "tabla" },
                "titulo": { "type": "string", "minLength": 1 },
                "orientacion": {
                    "type": "string",
                    "enum": ["portrait", "landscape"],
                    "default": "portrait"
                },
                "encabezados": {
                    "type": "array",
                    "items": { "type": "string" },
                    "minItems": 1
                },
                "filas": {
                    "type": "array",
                    "items": {
                        "type": "array",
                        "items": { "type": "string" }
                    }
                },
                "celdas_fusionadas": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "required": ["fila", "col"],
                        "properties": {
                            "fila": { "type": "integer", "minimum": 0 },
                            "col": { "type": "integer", "minimum": 0 },
                            "filas_span": { "type": "integer", "minimum": 1, "default": 1 },
                            "cols_span": { "type": "integer", "minimum": 1, "default": 1 }
                        },
                        "additionalProperties": false
                    }
                },
                "nota_pie": { "type": "string" },
                "estilo": {
                    "type": "object",
                    "properties": {
                        "encabezado_color": { "type": "string", "pattern": "^[0-9A-Fa-f]{6}$" },
                        "fuente_size": { "type": "number", "minimum": 6, "maximum": 18 },
                        "ancho_columnas": { "type": "array", "items": { "type": "number" } }
                    },
                    "additionalProperties": false
                }
            },
            "additionalProperties": false
        },
        "objetivo_grupo": {
            "type": "object",
            "properties": {
                "general": { "type": "string" },
                "especificos": { "type": "array", "items": { "type": "string" } }
            }
        }
    }
}
